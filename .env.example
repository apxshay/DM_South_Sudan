# Copy to .env and adjust for your environment (never commit .env).
#
# Windows 10 + AMD Ryzen 5 (recommended benchmark host):
#   Use defaults below — both Neo4j and PostGIS run native linux/amd64 in Docker.
#
# macOS Apple Silicon:
#   If local PostgreSQL already uses port 5432, set POSTGRES_PORT=5433.

# PostgreSQL / PostGIS
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=dm_ssd
POSTGRES_PASSWORD=dm_ssd_dev
POSTGRES_DB=dm_south_sudan

# Neo4j
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=dm_ssd_dev
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
